# AgroConnect — Environment Variables
# Copy to apps/api/.env and apps/web/.env.local
# NEVER commit .env or .env.local to git

NODE_ENV=development
PORT=4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000

# Database (Docker local)
DATABASE_URL=postgresql://agroconnect:agroconnect_dev@localhost:5432/agroconnect

# Redis (Docker local)
REDIS_URL=redis://:agroconnect_redis@localhost:6379

# Supabase — https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJ...YOUR_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=agroconnect

# Paystack — https://dashboard.paystack.com
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_YOUR_PUBLIC_KEY
PAYSTACK_SECRET_KEY=sk_test_YOUR_SECRET_KEY
PAYSTACK_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Arkesel (Ghana SMS + USSD) — https://arkesel.com
ARKESEL_API_KEY=YOUR_ARKESEL_API_KEY
ARKESEL_SENDER_ID=AGROCON
ARKESEL_USSD_SECRET=YOUR_USSD_INTERNAL_SECRET

# Resend (email for buyers) — https://resend.com
RESEND_API_KEY=re_YOUR_KEY
RESEND_FROM_EMAIL=noreply@agroconnect.io
RESEND_FROM_NAME=AgroConnect

# Security
JWT_SECRET=GENERATE_64_CHAR_RANDOM_HEX_NODEJS
CORS_ORIGINS=http://localhost:3000,https://agroconnect.io

# Super Admin
SUPER_ADMIN_PHONE=+233200000000

# Platform fees (as decimals)
PLATFORM_FEE_DIRECT=0.03
PLATFORM_FEE_PLEDGE=0.025
PLATFORM_FEE_INPUT=0.015

# Limits
MAX_IMAGE_SIZE_MB=5
MAX_FARM_PHOTOS=10
OTP_EXPIRY_SECONDS=600

# Rate limiting
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_AUTH=10

# Open-Meteo — free, no key needed
# Ghana Meteorological Agency data is free for non-commercial use
