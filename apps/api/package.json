{
  "name": "@agroconnect/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":       "tsx watch src/server.ts",
    "build":     "tsc",
    "start":     "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run",
    "seed":      "tsx src/seed.ts"
  },
  "dependencies": {
    "@agroconnect/database":   "workspace:*",
