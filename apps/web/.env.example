# AgroConnect Web — Frontend Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Supabase — https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...YOUR_ANON_KEY

# API URL — your deployed Fastify backend
NEXT_PUBLIC_API_URL=https://api.agroconnect.com.gh/api/v1

# Paystack public key — https://dashboard.paystack.com
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_YOUR_PUBLIC_KEY

# App URL (used for OG images and canonical URLs)
NEXT_PUBLIC_APP_URL=https://agroconnect.com.gh
