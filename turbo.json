{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["apps/web/.next/**", "!.next/cache/**", "dist/**"]
    },
    "dev":       { "cache": false, "persistent": true },
    "lint":      { "dependsOn": ["^lint"] },
    "typecheck": { "dependsOn": ["^typecheck"] },
    "test":      { "dependsOn": ["^build"], "outputs": ["coverage/**"] },
    "generate":  { "cache": false },
    "migrate":   { "cache": false },
    "seed":      { "cache": false },
    "clean":     { "cache": false }
  }
}
